# Copy to .env.local and fill from Supabase: Project Settings > API
# Use the Project URL only (https://xxxx.supabase.co) — do not add /rest/v1/ or other paths.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: fixed redirect for email confirmation in local dev (must be in Supabase Auth redirect allowlist)
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback
