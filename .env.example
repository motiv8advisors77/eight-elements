# Copy to .env.local and fill from Supabase: Project Settings > API
# Use the Project URL only (https://xxxx.supabase.co) — do not add /rest/v1/ or other paths.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Production / preview: set in Vercel to your deployment URL (no trailing slash), e.g.
#   https://your-app.vercel.app
# Optional locally: absolute app URL when `window` is unavailable (SSR); defaults to http://localhost:3000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: override email confirmation redirect (see lib/auth-email-redirect.ts). Usually leave unset;
# the app uses {SITE_URL or origin}/auth/callback. In Supabase Dashboard → Authentication → URL
# configuration, add the same callback URLs for local and each Vercel URL you use, e.g.
#   http://localhost:3000/auth/callback
#   https://your-app.vercel.app/auth/callback
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=
